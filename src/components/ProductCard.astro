---
import type { Product } from "../lib/types";
import { formatMoney } from "../lib/money";

interface Props {
  product: Product;
  /** Base path for product pages, e.g. "/shop". */
  basePath?: string;
}

const { product, basePath = "/shop" } = Astro.props;
const soldOut = !product.inStock || product.quantity === 0;
const href = `${basePath}/${product.slug}`;
---

<a class="shop-card" href={href} data-product-id={product.id} aria-label={product.name}>
  {product.image && (
    <img class="shop-card__img" src={product.image.src} alt={product.image.alt} loading="lazy" decoding="async" />
  )}
  <div class="shop-card__body">
    <h3 class="shop-card__name">{product.name}</h3>
    <p class="shop-card__price">{formatMoney(product.price)}</p>
    {soldOut && <span class="shop-card__badge">Sold out</span>}
  </div>
</a>

<style>
  /* Theme via --shop-* tokens; each site maps its own palette onto these. */
  .shop-card {
    display: block;
    overflow: hidden;
    border-radius: var(--shop-radius, 8px);
    background: var(--shop-bg, #fff);
    color: var(--shop-ink, #222);
    border: 1px solid var(--shop-rule, #e6e6e6);
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .shop-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }
  .shop-card__img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }
  .shop-card__body {
    padding: 0.75rem 0.9rem 1rem;
    font-family: var(--shop-font, sans-serif);
  }
  .shop-card__name { margin: 0; font-size: 1rem; }
  .shop-card__price {
    margin: 0.25rem 0 0;
    font-weight: 700;
    color: var(--shop-accent, #004cef);
  }
  .shop-card__badge {
    display: inline-block;
    margin-top: 0.4rem;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--shop-soldout-bg, #333);
    color: var(--shop-soldout-ink, #fff);
  }
</style>
