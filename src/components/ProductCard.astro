---
import type { Product } from "../lib/types";
import { formatMoney } from "../lib/money";
import AddToCartButton from "./AddToCartButton.astro";

interface Props {
  product: Product;
  basePath?: string;
}

const { product, basePath = "/shop" } = Astro.props;
const soldOut = !product.inStock || product.quantity === 0;
const href = `${basePath}/${product.slug}`;
---

<div class="shop-card">
  <a class="shop-card__link" href={href}>
    {product.image && (
      <img class="shop-card__img" src={product.image.src} alt={product.image.alt} loading="lazy" decoding="async" />
    )}
    <h3 class="shop-card__name">{product.name}</h3>
  </a>
  <div class="shop-card__foot">
    <span class="shop-card__price">{formatMoney(product.price)}</span>
    {soldOut ? (
      <span class="shop-card__badge">Sold out</span>
    ) : (
      <AddToCartButton product={product} basePath={basePath} />
    )}
  </div>
</div>

<style>
  .shop-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--shop-radius, 8px);
    background: var(--shop-bg, #fff);
    color: var(--shop-ink, #222);
    border: 1px solid var(--shop-rule, #e6e6e6);
    font-family: var(--shop-font, sans-serif);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .shop-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .shop-card__link:hover .shop-card__name { text-decoration: underline; }
  .shop-card__link:focus-visible { outline: 2px solid var(--shop-accent, #004cef); outline-offset: 2px; }
  .shop-card__img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    transition: transform 0.25s ease;
  }
  /* Hover affordances only where a real pointer exists (no sticky states on touch) */
  @media (hover: hover) {
    .shop-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(0, 0, 0, 0.12); }
    .shop-card:hover .shop-card__img { transform: scale(1.03); }
  }
  .shop-card__name { margin: 0.75rem 0.9rem 0; font-size: 1rem; }
  .shop-card__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
    padding: 0.75rem 0.9rem 0.9rem;
  }
  .shop-card__price { font-weight: 700; color: var(--shop-accent, #004cef); }
  .shop-card__badge {
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--shop-soldout-bg, #333);
    color: var(--shop-soldout-ink, #fff);
  }
</style>
