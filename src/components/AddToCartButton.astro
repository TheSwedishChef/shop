---
import type { Product } from "../lib/types";

interface Props {
  product: Product;
  label?: string;
  basePath?: string;
}

const { product, label = "Add to cart", basePath = "/shop" } = Astro.props;
const soldOut = !product.inStock || product.quantity === 0;
const href = `${basePath}/${product.slug}`;
// External fulfillment: when a buy_url is set, hand off to it and bypass the cart
// entirely (print-on-demand / third-party). Takes precedence over stock — those
// items aren't stocked by us, so "sold out" never applies.
const external = product.buyUrl?.trim();
---

{external ? (
  <a
    class="shop-atc shop-atc--external"
    href={external}
    target="_blank"
    rel="noopener nofollow"
    data-buy-external
  >Buy Now <span aria-hidden="true">&nearr;</span></a>
) : soldOut ? (
  <button class="shop-atc" type="button" disabled>Sold out</button>
) : (
  <button
    class="shop-atc"
    type="button"
    data-add-to-cart
    data-id={product.id}
    data-slug={product.slug}
    data-href={href}
    data-name={product.name}
    data-amount={String(product.price.amount)}
    data-currency={product.price.currency}
    data-image={product.image?.src ?? ""}
  >{label}</button>
)}

<style>
  .shop-atc {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35em;
    font: inherit;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    padding: 0.55rem 1.1rem;
    border: 0;
    border-radius: var(--shop-radius, 8px);
    background: var(--shop-accent, #004cef);
    color: #fff;
    white-space: nowrap;
    min-height: 44px; /* comfortable touch target */
    transition: filter 0.12s ease, transform 0.08s ease;
  }
  .shop-atc:hover { filter: brightness(1.06); }
  .shop-atc:active { transform: translateY(1px); }
  .shop-atc:focus-visible { outline: 2px solid var(--shop-ink, #222); outline-offset: 2px; }
  .shop-atc[disabled] {
    cursor: default;
    background: var(--shop-soldout-bg, #333);
    opacity: 0.75;
  }
</style>
