---
import type { Product } from "../lib/types";
import { formatMoney } from "../lib/money";
import AddToCartButton from "./AddToCartButton.astro";

interface Props {
  product: Product;
  basePath?: string;
}

const { product, basePath = "/shop" } = Astro.props;
---

<article class="shop-detail">
  <a class="shop-detail__back" href={basePath}>&larr; Shop</a>

  <div class="shop-detail__layout">
    {product.image && (
      <img class="shop-detail__img" src={product.image.src} alt={product.image.alt} />
    )}

    <div class="shop-detail__info">
      <h1 class="shop-detail__name">{product.name}</h1>
      <p class="shop-detail__price">{formatMoney(product.price)}</p>
      {product.description && <p class="shop-detail__desc">{product.description}</p>}
      <AddToCartButton product={product} basePath={basePath} />
    </div>
  </div>
</article>

<style>
  .shop-detail { font-family: var(--shop-font, inherit); }
  .shop-detail__back {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--shop-accent, #004cef);
    text-decoration: none;
  }
  .shop-detail__back:hover { text-decoration: underline; }
  .shop-detail__layout { display: grid; gap: 1.5rem; }
  @media (min-width: 640px) {
    .shop-detail__layout { grid-template-columns: 1fr 1fr; align-items: start; }
  }
  .shop-detail__img {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--shop-radius, 8px);
    border: 1px solid var(--shop-rule, #e6e6e6);
  }
  .shop-detail__name { margin: 0 0 0.25rem; color: var(--shop-ink, inherit); }
  .shop-detail__price {
    margin: 0 0 1rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--shop-accent, #004cef);
  }
  .shop-detail__desc { margin: 0 0 1.5rem; line-height: 1.5; }
</style>
