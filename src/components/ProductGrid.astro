---
import type { Product } from "../lib/types";
import ProductCard from "./ProductCard.astro";

interface Props {
  products: Product[];
  basePath?: string;
}

const { products, basePath = "/shop" } = Astro.props;
---

<ul class="shop-grid" role="list">
  {products.map((product) => (
    <li><ProductCard product={product} basePath={basePath} /></li>
  ))}
</ul>

<style>
  .shop-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--shop-gap, 1.25rem);
    grid-template-columns: repeat(auto-fill, minmax(var(--shop-min, 220px), 1fr));
  }
  .shop-grid > li { margin: 0; }
</style>
